# Copy this file to .env.local and fill in your values.
# The app auto-loads .env.local at startup (see env.js).

# API-Football key (https://www.api-football.com/). Optional but recommended:
# without it the app still runs (Elo prior + public fixture data), with it you get
# player-level squad data, Moneyball ratings and richer AI previews.
APIFOOTBALL_KEY=

# Club season to pull per-player stats from (2025 = the 2025/26 season).
AF_SEASON=2025

# Never spend the last N API requests of the day (keeps manual predictions working).
AF_SAFE_MARGIN=25

# Optional: force the small 1.7B model even on big machines (PREDICTOR_SMALL=small).
# PREDICTOR_SMALL=small

# Optional: custom port (default 3060).
# PORT=3060
